	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\FootballCareerCompanion.Application\FootballCareerCompanion.Application.csproj" />
		<ProjectReference Include="..\FootballCareerCompanion.Infrastructure\FootballCareerCompanion.Infrastructure.csproj" />
	</ItemGroup>

</Project>
